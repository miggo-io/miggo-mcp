{
  "packages": {
    ".": {
      "release-type": "python",
      "package-name": "miggo-mcp",
      "include-component-in-tag": false,
      "extra-files": [
        {
          "type": "toml",
          "path": "pyproject.toml",
          "jsonpath": "$.project.version"
        },
        {
          "type": "json",
          "path": "manifest.json",
          "jsonpath": "$.version"
        },
        {
          "type": "toml",
          "path": "uv.lock",
          "jsonpath": "$.package[?(@.name.value=='miggo-mcp')].version"
        }
      ]
    }
  }
}
